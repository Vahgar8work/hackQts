                <div class="dropdown-menu" aria-labelledby="dropdownMenuLink">
                  <a class="dropdown-item" href="#">User</a>
                  <a class="dropdown-item" href="#">Vendor</a>
                </div>
  
            <div class="text-center text-lg-start mt-4 pt-2">
              <input type="radio" id="html" name="html" value="html" checked="true">
              <label for="html">login as a user</label><br>
              <input type="radio" id="css" name="fav_language" value="CSS">
              <label for="css">login as a vendor</label><br>
              <button  class="btn btn-success btn-lg" type="submit" value="Submit" style="padding-left: 2.5rem; padding-right: 2.5rem;">Login</button>
              <p class="small fw-bold mt-2 pt-1 mb-0">Don't have an account? <a href="#!"
                  class="link-danger">Register</a></p>
            </div>
  
          </form>
